# AIDEV-NOTE: Dev image with yt-dlp + ffmpeg + pnpm. Source is mounted via
# docker-compose volumes — this image just provides the runtime environment.
FROM node:22-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
      ffmpeg \
      python3 \
      pipx && \
    pipx install yt-dlp && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

ENV PATH="/root/.local/bin:$PATH"

RUN corepack enable && corepack prepare pnpm@9.15.4 --activate

WORKDIR /app
